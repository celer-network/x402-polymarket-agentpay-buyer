# Buyer AgentPay env template

# Seller
export SELLER_HOST=35.83.247.203
export SELLER_HTTP="http://${SELLER_HOST}:8403"
# SELLER_GRPC / RELAY_ADMIN are only needed for same-machine setups.
# Remote buyers can leave these empty — the buyer node connects via the relay
# address embedded in BUYER_PROFILE.
export SELLER_GRPC=""
export RELAY_ADMIN=""

# Network
export NETWORK=eip155:8453
export CHAIN_ID=8453
export RPC_URL="${RPC_URL:-https://mainnet.base.org}"

# Buyer secret (required — 64 hex chars, no 0x prefix)
export BUYER_KEY="<SET_ME_64_HEX_NO_0x>"

# Runtime paths
export NODE_BIN="${NODE_BIN:-skills/codex-buyer-agentpay/bin/node}"
export BUYER_PROFILE="/tmp/buyer-profile.json"
export BUYER_DATA_DIR="/tmp/x402-buyer-data"

# Channel behavior
# Set OPEN_CHANNEL_ON_START=1 only when opening a new channel for the first time.
# Keep 0 on re-runs to avoid AlreadyExists errors and on-chain transactions.
export OPEN_CHANNEL_ON_START=0
export CHANNEL_DEPOSIT=500000
export AGENTPAY_CHANNEL_TOKEN_ADDR=833589fcd6edb6e08f4c7c32d4f71b54bda02913

# ── Dashboard demo batch parameters ──────────────────────────────────────────
# LOCKED demo params: a 5-min historical window on BTC market 2239711, capped
# at 5 paginated paid calls (= 0.25 USDC max per RUN AGENT). Do not change
# these unless explicitly authorized — see CLAUDE.md "Demo parameters".
export BATCH_FROM=2026-05-14T10:31:39Z
export BATCH_TO=2026-05-14T10:36:39Z
export BATCH_MAX_PAGES=5
# GO_BIN is only needed as fallback if x402-client binary is missing
export GO_BIN="${GO_BIN:-/usr/local/go/bin/go}"

# ── Optional: stream status events to an observation tool ────────────────────
# When set, the buyer scripts post each payment-flow event to this URL.
# The status-bridge dashboard (cmd/status-bridge/start-demo.sh) is one such
# consumer, but any HTTP endpoint that accepts JSON works. Leave empty to
# disable (events still go to stderr as JSON lines).
export AGENTPAY_STATUS_WEBHOOK=""

# Session ID for grouping events. Leave empty (or set AGENTPAY_SESSION_ID_AUTO=1)
# to have each script invocation mint a fresh session id.
export AGENTPAY_SESSION_ID=""
export AGENTPAY_SESSION_ID_AUTO=1
